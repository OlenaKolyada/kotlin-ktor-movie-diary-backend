{
  "request": {
    "method": "POST",
    "url": "/entry/kmp/read"
  },

  "response": {
    "status": 200,
    "jsonBody": {
      "responseType": "read",
      "result": "success",
      "entry": {
        "id": "{{{jsonPath request.body '$.entry.id'}}}",
        "userId": "user:12345",
        "movieId": "movie:tt0111161",
        "viewingDate": "2025-10-15",
        "rating": 9,
        "comment": "Потрясающий фильм о надежде"
      }
    },
    "headers": {
      "Content-Type": "application/json"
    },
    "transformers": ["response-template"]
  }
}
